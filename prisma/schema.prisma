// =============================================================
// Finarbo — Prisma Schema
// Provider: PostgreSQL (Supabase)
// =============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =============================================================
// AUTH — NextAuth v5 (Auth.js)
// =============================================================

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String?
  lastName       String?
  image          String?
  password       String?   // null si el usuario se registró con Google
  showOnboarding Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts   Account[]
  sessions   Session[]
  portfolios Portfolio[]
}

// Cuentas OAuth (Google). Requerido por NextAuth Prisma Adapter.
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// Sesiones. Requerido por NextAuth Prisma Adapter.
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Requerido por NextAuth para email verification (no usado en MVP pero necesario para el adapter).
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// =============================================================
// PORTFOLIO
// =============================================================

model Portfolio {
  id                    String        @id @default(cuid())
  userId                String
  name                  String
  // Perfil calculado por el motor de riesgo a partir del totalRiskScore.
  // Null hasta que se corra el primer análisis.
  calculatedRiskProfile RiskProfile?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  kyc       PortfolioKYC?
  positions Position[]
  insights  Insight[]
  snapshots AnalysisSnapshot[]
}

// KYC por cartera. La tolerancia es declarada por el usuario en lenguaje coloquial.
// No representa el perfil calculado — ese está en Portfolio.calculatedRiskProfile.
model PortfolioKYC {
  id             String        @id @default(cuid())
  portfolioId    String        @unique
  // Tolerancia declarada por el usuario:
  // PRESERVE  → "Prefiero no perder plata, aunque gane poco"
  // BALANCED  → "Prefiero que crezca de forma equilibrada"
  // GROWTH    → "Prefiero maximizar ganancias, aunque tenga subidas y bajadas"
  riskTolerance  RiskTolerance
  horizon        Horizon
  objective      Objective
  objectiveText  String?       // campo libre opcional para Objective.OTHER o SPECIFIC_GOAL
  currency       Currency

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
}

// Posiciones individuales cargadas por el usuario (una fila por activo del CSV/XLSX).
model Position {
  id          String   @id @default(cuid())
  portfolioId String
  ticker      String
  quantity    Float
  avgBuyPrice Float    // precio promedio ponderado de compra (pppCompra en el CSV)
  createdAt   DateTime @default(now())

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
}

// =============================================================
// ANÁLISIS
// =============================================================

// Snapshot del score total de riesgo cada vez que se corre un análisis.
// Alimenta el gráfico de evolución de riesgo en la pantalla de análisis.
model AnalysisSnapshot {
  id               String   @id @default(cuid())
  portfolioId      String
  totalRiskScore   Float    // suma de holdingRiskScore de todos los activos (0–1)
  portfolioAlertLevel AlertLevel
  createdAt        DateTime @default(now())

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
}

// Insights generados por LLM para la cartera.
// Se descartan al marcarlos (útil/no útil), el sistema aprende preferencias.
model Insight {
  id          String      @id @default(cuid())
  portfolioId String
  type        InsightType
  title       String
  body        String
  isUseful    Boolean?    // null = sin respuesta, true = útil, false = no útil
  dismissedAt DateTime?   // momento en que el usuario lo descartó
  createdAt   DateTime    @default(now())

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
}

// =============================================================
// ENUMS
// =============================================================

// Tolerancia al riesgo declarada por el usuario en el KYC.
enum RiskTolerance {
  PRESERVE // "Prefiero no perder plata, aunque gane poco"
  BALANCED // "Prefiero que crezca de forma equilibrada"
  GROWTH   // "Prefiero maximizar ganancias, aunque tenga subidas y bajadas"
}

// Perfil de riesgo calculado por el motor a partir del riskScore del portafolio.
// Mapea el totalRiskScore a una categoría: 0–0.19 → VERY_CONSERVATIVE ... ≥0.80 → VERY_AGGRESSIVE
enum RiskProfile {
  VERY_CONSERVATIVE
  CONSERVATIVE
  MODERATE
  AGGRESSIVE
  VERY_AGGRESSIVE
}

// Nivel de alerta global del portafolio (refleja qué tan cerca está del riesgo máximo).
enum AlertLevel {
  VERY_LOW
  LOW
  MEDIUM
  HIGH
  VERY_HIGH
}

// Horizonte temporal de inversión declarado en el KYC.
enum Horizon {
  SHORT  // < 1 año
  MEDIUM // 1–5 años
  LONG   // > 5 años
}

// Objetivo principal de inversión declarado en el KYC.
enum Objective {
  GROW_SAVINGS         // "Quiero hacer crecer mis ahorros"
  SPECIFIC_GOAL        // "Estoy ahorrando para algo específico (vacaciones, auto, casa...)"
  LIVE_FROM_INVESTMENTS // "Quiero vivir de mis inversiones"
  OTHER                // Campo libre — ver objectiveText
}

// Moneda de referencia de la cartera (para mostrar valores en el análisis).
enum Currency {
  ARS
  USD
}

// Tipo de insight generado por el LLM.
enum InsightType {
  ALERT    // Alerta — algo potencialmente problemático
  INFO     // Información neutral sobre la composición
  POSITIVE // Algo que está bien en la cartera
}
